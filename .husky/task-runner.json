{
  "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
  "tasks": [
    {
      "name": "dotnet-format-staged",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "format",
        "mygamebuilder-local.slnx",
        "--include",
        "${staged}",
        "--verbosity",
        "minimal"
      ],
      "include": [
        "**/*.cs"
      ]
    }
  ]
}