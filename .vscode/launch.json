{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Local Backend",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/src/MyGameBuilder.Local.Api/bin/Debug/net10.0/mygamebuilder-local.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/MyGameBuilder.Local.Api",
      "stopAtEntry": false,
      "console": "internalConsole",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://127.0.0.1:3000"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s"
      }
    }
  ]
}
