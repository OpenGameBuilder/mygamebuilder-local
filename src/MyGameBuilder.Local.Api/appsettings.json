{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:3000"
      }
    }
  },
  "PieceStore": {
    "ArchiveRoot": "archive",
    "DataRoot": "data"
  },
  "Frontend": {
    "RootPath": "frontend",
    "SwfName": "MGB.swf"
  },
  "Server": {
    "MaxQuotaKb": 16384
  }
}
